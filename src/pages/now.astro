---
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = new Date('2026-03-13');
---

<BaseLayout pageTitle="Now" description="What Steve Hill is doing now">
	<h1>Now</h1>
	<p class="subtitle">What I'm doing now</p>

	<div class="last-updated">
		Last updated: {lastUpdated.toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric'
		})}
	</div>

	<section>
		<h2>Currently Working On</h2>
		<ul>
			<li><strong><a href="https://www.resourceguruapp.com" target="_blank" rel="noopener">Resource Guru</a></strong> — my day job. Rails scheduling platform, full-stack and infrastructure</li>
			<li><strong><a href="https://www.code198x.com" target="_blank" rel="noopener">Code Like It's 198x</a></strong> — assembly programming education platform, now at its own domain</li>
			<li>Freelance client work — Rails applications and infrastructure</li>
		</ul>
	</section>

	<section>
		<h2>Learning</h2>
		<ul>
			<li>Z80, 6502, and 68000 assembly for the Code198x curriculum</li>
			<li>Building cycle-accurate CPU emulators (Z80, 6502, 68000) alongside Code198x</li>
		</ul>
	</section>

	<section>
		<h2>On Hold</h2>
		<ul>
			<li><strong><a href="/projects/rachel">Rachel</a></strong> — strategic card game, iOS port pending Apple Developer subscription</li>
			<li><strong><a href="/projects/chaotic-tanx">Chaotic Tanx</a></strong> — artillery game, same</li>
			<li><strong><a href="/projects/romshelf">Romshelf</a></strong> — Rust/Tauri ROM collection manager, parked for now</li>
		</ul>
	</section>

	<section>
		<h2>Life</h2>
		<ul>
			<li>Living in the UK</li>
			<li>Enjoying retro gaming and preserving gaming history</li>
		</ul>
	</section>

	<section class="now-about">
		<p>This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener">now page</a>,
		and if you have your own site, <a href="https://nownownow.com/about" target="_blank" rel="noopener">you should make one</a>, too.</p>
	</section>
</BaseLayout>

<style>
	h1 {
		margin-top: var(--spacing-2xl);
		color: var(--color-purple); /* Fallback */
		background: var(--gradient-sunrise);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		color: transparent;
	}

	.subtitle {
		font-style: italic;
		color: var(--color-text-secondary);
		margin-top: calc(-1 * var(--spacing-lg));
		margin-bottom: var(--spacing-xl);
	}

	.last-updated {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border);
		padding: var(--spacing-md) var(--spacing-lg);
		border-radius: var(--radius-md);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-xl);
		display: inline-block;
	}

	section {
		margin: var(--spacing-2xl) 0;
	}

	section ul {
		list-style: none;
		padding: 0;
	}

	section li {
		margin-bottom: var(--spacing-md);
		padding-left: var(--spacing-xl);
		position: relative;
		line-height: var(--line-height-relaxed);
	}

	section li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: var(--color-text-tertiary);
		font-weight: var(--font-weight-bold);
	}

	.now-about {
		margin-top: var(--spacing-2xl);
		padding-top: var(--spacing-xl);
		border-top: 1px solid var(--color-border);
	}

	.now-about p {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: var(--line-height-relaxed);
	}

	.now-about a {
		color: var(--color-text-primary);
		text-decoration: underline;
		text-decoration-color: rgba(139, 92, 246, 0.5);
		text-underline-offset: 0.2em;
		transition: all var(--transition-fast);
	}

	.now-about a:hover {
		color: var(--color-pink);
		text-decoration-color: var(--color-pink);
	}

	@media (max-width: 768px) {
		h1 {
			font-size: var(--font-size-2xl);
		}

		section h2 {
			font-size: var(--font-size-xl);
		}

		section li {
			padding-left: var(--spacing-lg);
		}
	}
</style>
